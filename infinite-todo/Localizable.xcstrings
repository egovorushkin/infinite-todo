    "All %lld tasks in this list, including their subtasks, will be deleted. This can't be undone.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle %lld Aufgaben in dieser Liste, einschließlich ihrer Unteraufgaben, werden gelöscht. Dies kann nicht widerrufen werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se eliminarán las %lld tareas de esta lista, incluidas sus subtareas. Esta acción no se puede deshacer."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все %lld задач в этом списке, включая подзадачи, будут удалены. Это действие нельзя отменить."
          }
        }
      }
    },
    "All nested subtasks will be deleted too. This can't be undone.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle verschachtelten Unteraufgaben werden ebenfalls gelöscht. Dies kann nicht widerrufen werden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todas las subtareas anidadas también se eliminarán. Esta acción no se puede deshacer."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все вложенные подзадачи также будут удалены. Это действие нельзя отменить."
          }
        }
      }
    },
