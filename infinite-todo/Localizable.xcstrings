  "strings": {
    "A task is due soon": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Eine Aufgabe ist bald fällig"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una tarea está próxima a vencer"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Одна из задач скоро истекает"
          }
        }
      }
    },
